---
import Hero from '../components/Hero.astro';
import CommandExamples from '../components/CommandExamples.astro';
import Pipeline from '../components/Pipeline.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CTA from '../components/CTA.astro';
import '../styles/landing.css';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const docsUrl = `${baseUrl}overview/`;
const playgroundUrl = `${baseUrl}playground/`;
const textDslUrl = `${baseUrl}reference/text-dsl/`;
const englishUrl = `${baseUrl}en/`;
const features = [
  {
    title: 'Python と Text DSL',
    body: 'Manim 風 API と Mermaid / PlantUML 風の短い declarative syntax から、同じ Fluxion IR を生成します。',
  },
  {
    title: '安全なブラウザ compiler',
    body: 'Text DSL は任意の Python code を実行せず、ブラウザ上で `.fluxion.json` へ変換できます。',
  },
  {
    title: 'SVG Runtime',
    body: 'Timeline operation を deterministic に適用し、play / seek / scrub / reset できる runtime で preview します。',
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fluxion - 編集可能な animation IR</title>
    <meta
      name="description"
      content="Fluxion は Python DSL と Text DSL から編集可能な Scene Graph / Timeline IR を生成し、ブラウザ SVG Runtime で再生します。"
    />
  </head>
  <body>
    <div class="shell">
      <nav aria-label="Primary navigation">
        <a class="brand" href={baseUrl}><span class="logo">F</span><span>Fluxion</span></a>
        <div class="links">
          <a href={docsUrl}>Docs</a>
          <a href={textDslUrl}>Text DSL</a>
          <a href={playgroundUrl}>Playground</a>
          <a class="language-link" href={englishUrl} hreflang="en">English</a>
        </div>
      </nav>

      <main>
        <Hero
          eyebrow="編集可能な animation IR"
          title="動画フレームではなく、編集可能な Scene Graph Timeline を生成する。"
          lead={'Fluxion は Manim 風 Python DSL とブラウザ Text DSL から <code>.fluxion.json</code> を生成し、SVG Runtime で再生するための実験的な animation authoring toolkit です。'}
          primaryHref={playgroundUrl}
          primaryLabel="Playground を開く"
          secondaryHref={docsUrl}
          secondaryLabel="Docs を読む"
        />

        <CommandExamples
          locale="ja"
          playgroundUrl={playgroundUrl}
          textDslUrl={textDslUrl}
          eyebrow="Text DSL commands"
          heading="GitHub Pages 上で試せる DSL 命令"
          intro="Text DSL は 1 行 1 命令で Scene Graph と Timeline を組み立てます。各カードのサンプルコードは「この場で実行」からすぐにインラインプレビューでき、必要に応じて Playground でも開けます。"
          runLabel="この場で実行"
          openLabel="Playground で開く"
          runnerTitle="インラインプレビュー"
          runnerStatus="コマンドサンプルを選ぶとここで実行します。"
          demoNote={{
            title: 'デモの流れ',
            items: [
              '<code>scene</code> と node 宣言で、再生領域・文字・数式・図形を定義します。',
              '<code>at</code> ブロックで開始時刻を固定し、<code>show</code> と <code>play</code> を順番に実行します。',
              '<code>set</code> と <code>animate</code> で円の色と座標を変え、<code>Transform</code> で矩形へ morph します。',
            ],
            playgroundLabel: 'Playground でデモを試す',
            referenceLabel: '詳しい Text DSL reference',
          }}
        />

        <Pipeline
          ariaLabel="Fluxion pipeline"
          label="Pipeline:"
          steps={['Python DSL / Text DSL', 'Scene Graph IR', 'Timeline IR', 'Browser SVG Runtime']}
        />

        <FeatureGrid ariaLabel="Fluxion highlights" features={features} />

        <CTA
          title="まずは Text DSL をブラウザで試す。"
          body="インストールなしで DSL を編集し、生成される Scene Graph / Timeline IR と SVG preview を確認できます。"
          primaryHref={playgroundUrl}
          primaryLabel="Playground を開く"
          secondaryHref={textDslUrl}
          secondaryLabel="Text DSL reference"
        />
      </main>

      <footer>
        Fluxion is an MVP for generating editable animation IR instead of rendered video frames.
      </footer>
    </div>
  </body>
</html>
