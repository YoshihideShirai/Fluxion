---
import Hero from '../components/Hero.astro';
import CommandExamples from '../components/CommandExamples.astro';
import Pipeline from '../components/Pipeline.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CTA from '../components/CTA.astro';
import '../styles/landing.css';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const docsUrl = `${baseUrl}overview/`;
const playgroundUrl = `${baseUrl}playground/`;
const textDslUrl = `${baseUrl}reference/text-dsl/`;
const englishUrl = `${baseUrl}en/`;
const galleryUrl = `${baseUrl}gallery/`;
const features = [
  {
    title: '編集し続けられる成果物',
    body: '動画を書き出して終わりではなく、Scene Graph / Timeline IR を残すので、あとから要素やタイミングを再編集できます。',
  },
  {
    title: '非エンジニアとも共有しやすい',
    body: 'Text DSL は 1 行 1 命令で読みやすく、Playground でそのまま動作確認できるため、仕様レビューや合意形成が速くなります。',
  },
  {
    title: '導入が軽く、安全に試せる',
    body: 'ブラウザ上で任意の Python を実行せずに `.fluxion.json` を生成し、SVG Runtime ですぐ preview できるため、初期検証の負荷を抑えられます。',
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fluxion - 編集可能な animation IR</title>
    <meta
      name="description"
      content="Fluxion は Python DSL と Text DSL から編集可能な Scene Graph / Timeline IR を生成し、ブラウザ SVG Runtime で再生します。"
    />
  </head>
  <body>
    <div class="shell">
      <nav aria-label="Primary navigation">
        <a class="brand" href={baseUrl}><span class="logo">F</span><span>Fluxion</span></a>
        <div class="links">
          <a href={docsUrl}>Docs</a>
          <a href={textDslUrl}>Text DSL</a>
          <a href={playgroundUrl}>Playground</a>
          <a href={galleryUrl}>Gallery</a>
          <div class="language-switcher" aria-label="Language selector">
            <a class="language-option is-current" href={baseUrl} hreflang="ja" aria-current="page">日本語</a>
            <a class="language-option" href={englishUrl} hreflang="en">English</a>
          </div>
        </div>
      </nav>

      <main>
        <Hero
          eyebrow="Fluxion の概要"
          title="Fluxion は、アニメーションを“あとから編集できる状態”で作るためのソフトウェアです。"
          lead={'Fluxion は Python DSL / Text DSL から Scene Graph と Timeline を IR として生成し、ブラウザで再生・検証できます。<strong>作って終わり</strong>ではなく、内容や演出を継続的に改善しやすいことが最大のメリットです。'}
          primaryHref={playgroundUrl}
          primaryLabel="Playground を開く"
          secondaryHref={docsUrl}
          secondaryLabel="Docs を読む"
        />

        <CommandExamples
          locale="ja"
          playgroundUrl={playgroundUrl}
          textDslUrl={textDslUrl}
          eyebrow="Text DSL commands"
          heading="GitHub Pages 上で体験できる Fluxion"
          intro="Text DSL は 1 行 1 命令で Scene Graph と Timeline を組み立てます。短い命令列を動かしながら、Fluxion がどのように“編集可能な成果物”を作るかをその場で確認できます。"
          runLabel="この場で実行"
          openLabel="Playground で開く"
          runnerTitle="インラインプレビュー"
          runnerStatus="コマンドサンプルを選ぶとここで実行します。"
          demoNote={{
            title: 'デモの流れ',
            items: [
              '<code>scene</code> と node 宣言で、再生領域・文字・数式・図形を定義します。',
              '<code>at</code> ブロックで開始時刻を固定し、<code>show</code> と <code>play</code> を順番に実行します。',
              '<code>set</code> と <code>animate</code> で円の色と座標を変え、<code>Transform</code> で矩形へ morph します。',
            ],
            playgroundLabel: 'Playground でデモを試す',
            referenceLabel: '詳しい Text DSL reference',
          }}
        />

        <Pipeline
          ariaLabel="Fluxion pipeline"
          label="Pipeline:"
          steps={['Python DSL / Text DSL', 'Scene Graph IR', 'Timeline IR', 'Browser SVG Runtime']}
        />

        <FeatureGrid ariaLabel="Fluxion highlights" features={features} />

        <CTA
          title="まずは概要をつかみ、メリットを体験する。"
          body="Playground で Text DSL を数行編集するだけで、再編集可能な IR と SVG preview を確認できます。Fluxion の価値を最短で理解したい人に最適です。"
          primaryHref={playgroundUrl}
          primaryLabel="Playground を開く"
          secondaryHref={textDslUrl}
          secondaryLabel="Text DSL reference"
        />
      </main>

      <footer>
        Fluxion is an MVP for generating editable animation IR instead of rendered video frames.
      </footer>
    </div>
  </body>
</html>
