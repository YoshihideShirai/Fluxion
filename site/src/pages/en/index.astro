---
import Hero from '../../components/Hero.astro';
import CommandExamples from '../../components/CommandExamples.astro';
import Pipeline from '../../components/Pipeline.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import CTA from '../../components/CTA.astro';
import '../../styles/landing.css';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const docsUrl = `${baseUrl}en/overview/`;
const playgroundUrl = `${baseUrl}playground/`;
const textDslUrl = `${baseUrl}en/reference/text-dsl/`;
const japaneseUrl = baseUrl;
const features = [
  {
    title: 'Python and Text DSL',
    body: 'Generate the same Fluxion IR from a Manim-like API and a compact Mermaid/PlantUML-like declarative syntax.',
  },
  {
    title: 'Safe browser compiler',
    body: 'The Text DSL compiles to `.fluxion.json` in the browser without running arbitrary Python code.',
  },
  {
    title: 'SVG Runtime',
    body: 'Preview animations in a runtime that applies timeline operations deterministically and supports play, seek, scrub, and reset.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fluxion - Editable animation IR</title>
    <meta
      name="description"
      content="Fluxion generates editable Scene Graph / Timeline IR from Python DSL and Text DSL, then plays it in a browser SVG Runtime."
    />
  </head>
  <body>
    <div class="shell">
      <nav aria-label="Primary navigation">
        <a class="brand" href={baseUrl}><span class="logo">F</span><span>Fluxion</span></a>
        <div class="links">
          <a href={docsUrl}>Docs</a>
          <a href={textDslUrl}>Text DSL</a>
          <a href={playgroundUrl}>Playground</a>
          <a class="language-link" href={japaneseUrl} hreflang="ja">日本語</a>
        </div>
      </nav>

      <main>
        <Hero
          eyebrow="Editable animation IR"
          title="Generate editable Scene Graph Timelines, not rendered video frames."
          lead={'Fluxion is an experimental animation authoring toolkit that generates <code>.fluxion.json</code> from a Manim-like Python DSL and browser Text DSL, then plays it with an SVG Runtime.'}
          primaryHref={playgroundUrl}
          primaryLabel="Open Playground"
          secondaryHref={docsUrl}
          secondaryLabel="Read Docs"
        />

        <CommandExamples
          locale="en"
          playgroundUrl={playgroundUrl}
          textDslUrl={textDslUrl}
          eyebrow="Text DSL commands"
          heading="DSL commands you can try on GitHub Pages"
          intro={'Text DSL builds a Scene Graph and Timeline with one command per line. Use each card’s sample code with “Run here” to preview the command inline, or open the same sample in the Playground.'}
          runLabel="Run here"
          openLabel="Open in Playground"
          runnerTitle="Inline preview"
          runnerStatus="Choose a command sample to run."
          demoNote={{
            title: 'What the demo shows',
            items: [
              '<code>scene</code> and node declarations define the viewport, labels, equation, and shapes.',
              'The <code>at</code> block pins the starting time, then runs <code>show</code> and <code>play</code> in sequence.',
              '<code>set</code> and <code>animate</code> change the circle color and x position before <code>Transform</code> morphs it toward the rectangle.',
            ],
            playgroundLabel: 'Try the demo in Playground',
            referenceLabel: 'Read the full Text DSL reference',
          }}
        />

        <Pipeline
          ariaLabel="Fluxion pipeline"
          label="Pipeline:"
          steps={['Python DSL / Text DSL', 'Scene Graph IR', 'Timeline IR', 'Browser SVG Runtime']}
        />

        <FeatureGrid ariaLabel="Fluxion highlights" features={features} />

        <CTA
          title="Try Text DSL in your browser first."
          body="Edit DSL without installing anything, then inspect the generated Scene Graph / Timeline IR and SVG preview."
          primaryHref={playgroundUrl}
          primaryLabel="Open Playground"
          secondaryHref={textDslUrl}
          secondaryLabel="Text DSL reference"
        />
      </main>

      <footer>
        Fluxion is an MVP for generating editable animation IR instead of rendered video frames.
      </footer>
    </div>
  </body>
</html>
