---
import GalleryPage from '../../components/GalleryPage.astro';
import { getGalleryDemos } from '../../data/galleryDemos';

const demos = await getGalleryDemos();
---
<GalleryPage
  title="Fluxion × Manim Example Gallery"
  intro="GitHub Pages gallery inspired by Manim examples. `fidelity=faithful` means behavior-oriented parity, while `visual_approximation` means visual-first approximation. Check each card's gap notes before comparing outputs. Across the DSL, coordinates are scene-centered with (0,0) at the canvas center."
  locale="en"
  demos={demos}
/>
