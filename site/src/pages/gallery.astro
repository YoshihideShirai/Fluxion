---
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const playgroundUrl = `${baseUrl}playground/`;
const demos = [
  {
    title: 'Orbit + Morph',
    description: '円運動から Transform でカードへ morph。カメラ移動と式連動も確認できます。',
    source: `scene width=960 height=540 fps=60
value theta = 0
rect bg w=960 h=540 at 480,270 fill="#020617"
path orbit d="M -140 0 C -140 -77 -77 -140 0 -140 C 77 -140 140 -77 140 0 C 140 77 77 140 0 140 C -77 140 -140 77 -140 0" at 480,280 fill="none" stroke="#1d4ed8" strokeWidth=4 opacity=0.55
circle dot r=28 at 340,280 fill="#38bdf8" stroke="#0f172a" strokeWidth=4
rect card w=180 h=92 at 740,280 fill="#f97316" stroke="#fed7aa" strokeWidth=4
text title "Orbit to Card" at 480,90 size=40 fill="#e2e8f0"
at 0s:
  hide card
  play AnimationGroup(Write(title), FadeIn(orbit), FadeIn(dot), lagRatio=0.15) duration=1.2s easing=easeOut
animate theta from 0 to 6.283 duration=2.2s easing=linear
set dot.x to expr="480 + 140 * cos(theta)"
set dot.y to expr="280 + 140 * sin(theta)"
play FadeIn(card) start=2.2s duration=0.5s easing=easeOut
play Transform(dot, card) start=2.5s duration=1.0s easing=easeInOut`
  },
  {
    title: 'Math Token Transform',
    description: 'TransformMatchingTex で数式のトークン変換をデモ。',
    source: `scene width=960 height=540 fps=60
rect bg w=960 h=540 at 480,270 fill="#111827"
math eq1 "x^2+y^2=r^2" at 480,220 size=58 fill="#bae6fd" renderer=katex expandTokens=true
math eq2 "x^2+y^2=R^2" at 480,220 size=58 fill="#fde68a" renderer=katex expandTokens=true
text label "Token-level equation morph" at 480,110 size=36 fill="#e5e7eb"
at 0s:
  hide eq2
  play FadeIn(label) duration=0.7s easing=easeOut
  play Write(eq1) duration=1.2s easing=easeOut
wait 0.4s
show eq2
play TransformMatchingTex(eq1, eq2) duration=1.3s easing=easeInOut`
  },
  {
    title: 'Staggered Group Animation',
    description: 'AnimationGroup と lagRatio で複数オブジェクトの段階表示。',
    source: `scene width=960 height=540 fps=60
rect bg w=960 h=540 at 480,270 fill="#0b1020"
text title "Staggered reveal" at 480,86 size=38 fill="#f8fafc"
circle a r=28 at 240,300 fill="#38bdf8"
circle b r=28 at 400,300 fill="#22c55e"
circle c r=28 at 560,300 fill="#f59e0b"
circle d r=28 at 720,300 fill="#f43f5e"
group dots a b c d
at 0s:
  play Write(title) duration=0.8s easing=easeOut
  play AnimationGroup(FadeIn(a), FadeIn(b), FadeIn(c), FadeIn(d), lagRatio=0.25) duration=1.8s easing=easeOut
animate dots.y from 300 to 250 start=2.0s duration=0.8s easing=easeInOut
animate dots.rotation from 0 to 360 start=2.0s duration=1.6s easing=linear`
  }
];
const encodeDsl = (source: string) => `${playgroundUrl}?dsl=${encodeURIComponent(source)}`;
---
<!doctype html>
<html lang="ja">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Fluxion Demo Gallery</title></head>
  <body>
    <main style="max-width:1100px;margin:0 auto;padding:32px 20px;font-family:system-ui">
      <h1>Fluxion Demo Gallery</h1>
      <p>GitHub Pages 上で「いろんなアニメーション」をすぐ試せるサンプル集です。</p>
      <p><a href={baseUrl}>← トップへ戻る</a></p>
      <section style="display:grid;gap:16px;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));margin-top:20px;">
        {demos.map((demo) => (
          <article style="border:1px solid #cbd5e1;border-radius:12px;padding:14px;">
            <h2 style="font-size:1.1rem;">{demo.title}</h2>
            <p>{demo.description}</p>
            <pre style="max-height:220px;overflow:auto;background:#0f172a;color:#e2e8f0;padding:10px;border-radius:8px;font-size:12px;"><code>{demo.source}</code></pre>
            <a href={encodeDsl(demo.source)}>Playground で開く</a>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>
