---
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const playgroundUrl = `${baseUrl}playground/`;
const demos = [
  {
    title: 'Opening Manim Community Banner',
    description: 'Inspired by Manim examples: staged title + subtitle reveal using LaggedStart.',
    source: `scene width=960 height=540 fps=60
rect bg w=960 h=540 at 480,270 fill="#030712"
text title "Manim Community" at 480,210 size=56 fill="#93c5fd"
text subtitle "Rendered with Fluxion DSL" at 480,290 size=32 fill="#e5e7eb"
at 0s:
  play LaggedStart(Write(title), FadeIn(subtitle), lagRatio=0.28) duration=1.8s easing=easeOut
at 2.8s:
  play FadeOut(subtitle) duration=0.8s easing=easeInOut`,
  },
  {
    title: 'Orbital Dot',
    description: 'Parametric movement using value trackers, expressions, and Transform.',
    source: `scene width=960 height=540 fps=60
value theta = 0
rect bg w=960 h=540 at 480,270 fill="#020617"
path orbit d="M -140 0 C -140 -77 -77 -140 0 -140 C 77 -140 140 -77 140 0 C 140 77 77 140 0 140 C -77 140 -140 77 -140 0" at 480,280 fill="none" stroke="#1d4ed8" strokeWidth=4 opacity=0.55
circle dot r=28 at 340,280 fill="#38bdf8" stroke="#0f172a" strokeWidth=4
rect card w=180 h=92 at 740,280 fill="#f97316" stroke="#fed7aa" strokeWidth=4
at 0s:
  hide card
  play AnimationGroup(FadeIn(orbit), FadeIn(dot), lagRatio=0.15) duration=1.1s easing=easeOut
animate theta from 0 to 6.283 duration=2.2s easing=linear
set dot.x to expr="480 + 140 * cos(theta)"
set dot.y to expr="280 + 140 * sin(theta)"
at 2.2s:
  play FadeIn(card) duration=0.5s easing=easeOut
at 2.5s:
  play Transform(dot, card) duration=1.0s easing=easeInOut`,
  },
  {
    title: 'Transform Matching Tex',
    description: 'Token-by-token math transform like Manim TransformMatchingTex.',
    source: `scene width=960 height=540 fps=60
rect bg w=960 h=540 at 480,270 fill="#111827"
math eq1 "x^2+y^2=r^2" at 480,220 size=58 fill="#bae6fd" renderer=katex expandTokens=true
math eq2 "x^2+y^2=R^2" at 480,220 size=58 fill="#fde68a" renderer=katex expandTokens=true
at 0s:
  hide eq2
  play Write(eq1) duration=1.2s easing=easeOut
wait 0.4s
show eq2
play TransformMatchingTex(eq1, eq2) duration=1.3s easing=easeInOut`,
  },
  {
    title: 'Simple Circle (Python DSL sample)',
    description: 'Text DSL version of examples/simple_circle.py: create one circle and fade it out.',
    source: `scene width=960 height=540 fps=60
circle circle r=80 at 480,270 fill="#38bdf8" stroke="#0f172a" strokeWidth=6
at 0s:
  play Create(circle) duration=1.0s easing=easeOut
wait 0.6s
play FadeOut(circle) duration=0.8s easing=easeInOut`,
  },
  {
    title: 'Basic Concepts: Square to Circle',
    description: 'Text DSL version of examples/basic_concepts_square_to_circle.py.',
    source: `scene width=960 height=540 fps=60
rect square w=170 h=170 at 480,270 fill="none" stroke="#38bdf8" strokeWidth=8
circle circle r=85 at 480,270 fill="#38bdf8" stroke="#bae6fd" strokeWidth=6 opacity=0
at 0s:
  play Create(square) duration=1.0s easing=easeOut
wait 0.3s
show circle
play Transform(square, circle) duration=1.1s easing=easeInOut
wait 0.3s
play FadeOut(square) duration=0.8s easing=easeInOut`,
  },
  {
    title: 'Animations Using .animate',
    description: 'Text DSL version of examples/animations_using_animate.py: shift, recolor, scale, rotate.',
    source: `scene width=960 height=540 fps=60
rect square w=160 h=160 at 300,270 fill="#38bdf8" stroke="#0f172a" strokeWidth=6
play FadeIn(square) duration=0.8s easing=easeOut
animate square.x from 300 to 640 duration=1.0s easing=easeInOut
animate square.fill from "#38bdf8" to "#f97316" duration=0.9s easing=easeInOut
animate square.scale from 1 to 1.9 duration=1.0s easing=easeOut
animate square.rotation from 0 to 180 duration=1.0s easing=easeInOut`,
  },
  {
    title: 'Plotting with Manim (Sin / Cos)',
    description: 'Text DSL version of examples/plotting_with_manim.py with axes and two curves.',
    source: `scene width=960 height=540 fps=60
line xAxis x1=-380 y1=0 x2=380 y2=0 at 480,300 stroke="#94a3b8" strokeWidth=3
line yAxis x1=0 y1=-180 x2=0 y2=180 at 480,300 stroke="#94a3b8" strokeWidth=3
path sinCurve d="M 0 0 C 64 -52 128 -52 192 0 C 256 52 320 52 384 0 C 448 -52 512 -52 576 0 C 640 52 704 52 768 0" at 96,300 fill="none" stroke="#38bdf8" strokeWidth=5
path cosCurve d="M 0 -48 C 64 -48 128 0 192 48 C 256 96 320 96 384 48 C 448 0 512 -48 576 -48 C 640 -48 704 0 768 48" at 96,300 fill="none" stroke="#f97316" strokeWidth=5
text sinLabel "sin(x)" at 770,210 size=28 fill="#38bdf8"
text cosLabel "cos(x)" at 770,250 size=28 fill="#f97316"
at 0s:
  play AnimationGroup(Create(xAxis), Create(yAxis), lagRatio=0.15) duration=0.9s easing=easeOut
  play AnimationGroup(Create(sinCurve), Create(cosCurve), FadeIn(sinLabel), FadeIn(cosLabel), lagRatio=0.1) duration=1.8s easing=easeInOut`,
  },
  {
    title: 'Special Camera Settings',
    description: 'Text DSL version of examples/special_camera_settings.py with camera pan and zoom.',
    source: `scene width=960 height=540 fps=60
camera at 0,0 scale=1
circle center r=70 at 480,270 fill="#38bdf8"
circle left r=42 at 280,270 fill="#22c55e"
circle right r=42 at 680,270 fill="#f97316"
text label "Camera move demo" at 480,120 size=34 fill="#e2e8f0"
at 0s:
  play AnimationGroup(FadeIn(center), FadeIn(left), FadeIn(right), Write(label), lagRatio=0.15) duration=1.2s easing=easeOut
animate camera.x from 0 to -120 duration=1.2s easing=easeInOut
animate camera.scale from 1 to 1.35 duration=1.2s easing=easeInOut
animate camera.x from -120 to 120 start=2.0s duration=1.2s easing=easeInOut
animate camera.scale from 1.35 to 1.0 start=2.0s duration=1.2s easing=easeInOut`,
  }
];
const encodeDsl = (source: string) => `${playgroundUrl}?dsl=${encodeURIComponent(source)}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fluxion × Manim Gallery</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.js"></script>
    <script>
      (window as any).MathJax = { tex: { inlineMath: [["\(", "\)"]] }, startup: { typeset: false } };
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>
  </head>
  <body>
    <main style="max-width:1200px;margin:0 auto;padding:32px 20px;font-family:system-ui">
      <h1>Fluxion × Manim Example Gallery</h1>
      <p>GitHub Pages gallery inspired by Manim examples. You can read Fluxion DSL and play each animation inline.</p>
      <p><a href={baseUrl}>← Back to home</a> / <a href={playgroundUrl}>Open Playground</a></p>
      <section style="display:grid;gap:16px;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));margin-top:20px;">
        {demos.map((demo, index) => (
          <article style="border:1px solid #cbd5e1;border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:12px;">
            <h2 style="font-size:1.1rem;margin:0;">{demo.title}</h2>
            <p style="margin:0;">{demo.description}</p>
            <div class="gallery-stage" id={`gallery-stage-${index}`} style="height:220px;border-radius:8px;border:1px solid #334155;background:#020617;"></div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button type="button" class="play-inline" data-source={demo.source} data-stage={`gallery-stage-${index}`}>Play</button>
              <button type="button" class="reset-inline" data-stage={`gallery-stage-${index}`}>Reset</button>
              <a href={encodeDsl(demo.source)}>Open in Playground</a>
            </div>
            <pre style="max-height:260px;overflow:auto;background:#0f172a;color:#e2e8f0;padding:10px;border-radius:8px;font-size:12px;"><code>{demo.source}</code></pre>
          </article>
        ))}
      </section>
    </main>
    <script is:inline define:vars={{ baseUrl }}>
      const players = new Map();
      const status = document.createElement('p');
      status.style.color = '#dc2626';
      status.style.marginTop = '12px';

      const runtimeCandidates = [
        `${baseUrl}playground/dist/index.js`,
        `${baseUrl}playground/dist/index.mjs`,
      ];
      const compilerCandidates = [
        `${baseUrl}playground/dist/dsl/compiler.js`,
        `${baseUrl}playground/dist/dsl/compiler.mjs`,
      ];

      async function importFirst(candidates) {
        let lastError;
        for (const url of candidates) {
          try {
            return await import(url);
          } catch (error) {
            lastError = error;
          }
        }
        throw lastError ?? new Error(`Failed to import ${candidates[0]}`);
      }

      async function bootGallery() {
        try {
          const runtime = await importFirst(runtimeCandidates);
          const compiler = await importFirst(compilerCandidates);
          const playButtons = [...document.querySelectorAll('.play-inline')];
          const resetButtons = [...document.querySelectorAll('.reset-inline')];

          const run = (stageId, dsl) => {
            const stage = document.getElementById(stageId);
            if (!stage) return;
            const prev = players.get(stageId);
            prev?.stop();
            const doc = compiler.compileTextDsl(dsl);
            const player = runtime.mountFluxionDocument(stage, doc);
            player.play({ from: 0 });
            players.set(stageId, player);
          };

          playButtons.forEach((button) => {
            button.addEventListener('click', () => {
              run(button.dataset.stage ?? '', button.dataset.source ?? '');
            });
            run(button.dataset.stage ?? '', button.dataset.source ?? '');
          });

          resetButtons.forEach((button) => {
            button.addEventListener('click', () => {
              const player = players.get(button.dataset.stage ?? '');
              if (!player) return;
              player.stop();
              player.seek(0);
            });
          });
        } catch (error) {
          status.textContent = 'Failed to load gallery runtime. Open Playground and rebuild web/dist if needed.';
          document.querySelector('main')?.appendChild(status);
          console.error(error);
        }
      }
      void bootGallery();
    </script>
  </body>
</html>
