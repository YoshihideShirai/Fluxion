---
import GalleryPage from '../components/GalleryPage.astro';
import { getGalleryDemos } from '../data/galleryDemos';

const demos = await getGalleryDemos();
---
<GalleryPage
  title="Fluxion × Manim Example Gallery"
  intro="GitHub Pages gallery inspired by Manim examples. fidelity=faithful は挙動をできる限り忠実移植、visual_approximation は見た目優先の近似移植を意味します。各カードの差分メモを確認しながら比較できます。"
  locale="ja"
  demos={demos}
/>
