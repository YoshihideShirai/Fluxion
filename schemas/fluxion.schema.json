{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluxion.local/schemas/fluxion.schema.json",
  "title": "Fluxion Document",
  "type": "object",
  "required": ["version", "width", "height", "fps", "nodes", "timeline"],
  "properties": {
    "version": { "const": "0.1" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "fps": { "type": "integer", "minimum": 1 },
    "duration": { "type": "number", "minimum": 0 },
    "nodes": { "type": "array", "description": "Top-level scene nodes. Every node id in this array and in any nested children array must be unique across the entire document because timeline operations resolve ids globally.", "items": { "$ref": "#/$defs/node" } },
    "timeline": { "type": "array", "items": { "$ref": "#/$defs/timelineOperation" } }
  },
  "$defs": {
    "transform": {
      "type": "object",
      "required": ["x", "y", "scale", "rotation", "opacity"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "scale": { "type": "number" },
        "rotation": { "type": "number" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "style": {
      "type": "object",
      "description": "Style values that may be animated by the runtime. fill/stroke CSS hex/rgb(a) strings are interpolated as colors; other strings use step fallback.",
      "properties": {
        "fill": { "$ref": "#/$defs/styleColor" },
        "stroke": { "$ref": "#/$defs/styleColor" },
        "strokeWidth": { "type": "number", "minimum": 0 }
      }
    },
    "styleColor": {
      "type": "string",
      "description": "CSS color string. Runtime interpolation supports hex (#rgb, #rgba, #rrggbb, #rrggbbaa) and rgb()/rgba(); unsupported strings fall back to step switching."
    },
    "numberArray": {
      "type": "array",
      "description": "Numeric vector. Runtime interpolation is element-wise when from/to arrays have identical lengths.",
      "items": { "type": "number" }
    },
    "interpolatableGeometryValue": {
      "description": "Geometry values supported by runtime interpolation: numbers, same-length number arrays, color/path strings where applicable, or step fallback strings.",
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        { "$ref": "#/$defs/numberArray" }
      ]
    },
    "node": {
      "type": "object",
      "required": ["id", "type", "transform", "style", "geometry", "children"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "description": "Unique node id. The id must be unique across the entire document, including children nested under group nodes, so timeline operations can target any node unambiguously." },
        "type": { "enum": ["group", "circle", "rect", "line", "path", "text", "math"] },
        "transform": { "$ref": "#/$defs/transform" },
        "style": { "$ref": "#/$defs/style" },
        "geometry": { "type": "object", "additionalProperties": { "$ref": "#/$defs/interpolatableGeometryValue" } },
        "children": { "type": "array", "description": "Nested child nodes, typically used by group nodes. Child ids share the same global namespace as top-level node ids.", "items": { "$ref": "#/$defs/node" } },
        "text": { "type": "string" },
        "latex": { "type": "string", "description": "LaTeX source passed to the selected math renderer." },
        "renderer": { "enum": ["katex", "mathjax"] }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "path" } }, "required": ["type"] },
          "then": { "properties": { "geometry": { "$ref": "#/$defs/pathGeometry" } } }
        },
        {
          "if": { "properties": { "type": { "const": "text" } }, "required": ["type"] },
          "then": { "required": ["text"], "properties": { "geometry": { "$ref": "#/$defs/textGeometry" } } }
        },
        {
          "if": { "properties": { "type": { "const": "math" } }, "required": ["type"] },
          "then": {
            "required": ["latex", "renderer"],
            "properties": {
              "latex": { "type": "string", "minLength": 1, "description": "LaTeX source passed to KaTeX or MathJax." },
              "renderer": { "enum": ["katex", "mathjax"], "description": "Math renderer implementation to use in SVG foreignObject HTML." },
              "geometry": { "$ref": "#/$defs/mathGeometry" }
            }
          }
        }
      ]
    },
    "pathGeometry": {
      "type": "object",
      "required": ["d"],
      "properties": {
        "d": { "type": "string", "description": "SVG path data. Runtime morphing supports only paths with the same command sequence and numeric arity; other path strings use step fallback." }
      }
    },
    "textGeometry": {
      "type": "object",
      "required": ["fontSize"],
      "properties": {
        "fontSize": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "mathGeometry": {
      "type": "object",
      "required": ["fontSize"],
      "description": "Math geometry. fontSize is required so KaTeX/MathJax render at a predictable size.",
      "properties": {
        "fontSize": { "type": "number", "exclusiveMinimum": 0, "description": "CSS pixel font size used by the math renderer." },
        "w": { "type": "number", "exclusiveMinimum": 0, "description": "Optional foreignObject width override in scene units." },
        "h": { "type": "number", "exclusiveMinimum": 0, "description": "Optional foreignObject height override in scene units." }
      }
    },
    "timelineOperation": {
      "oneOf": [
        { "$ref": "#/$defs/createOperation" },
        { "$ref": "#/$defs/deleteOperation" },
        { "$ref": "#/$defs/setOperation" },
        { "$ref": "#/$defs/animateOperation" },
        { "$ref": "#/$defs/effectOperation" }
      ]
    },
    "baseOperation": {
      "type": "object",
      "required": ["t", "op"],
      "properties": {
        "t": { "type": "number", "minimum": 0 },
        "op": { "type": "string" }
      }
    },
    "createOperation": {
      "allOf": [
        { "$ref": "#/$defs/baseOperation" },
        { "type": "object", "required": ["node"], "properties": { "op": { "const": "create" }, "node": { "$ref": "#/$defs/node" } } }
      ]
    },
    "deleteOperation": {
      "allOf": [
        { "$ref": "#/$defs/baseOperation" },
        { "type": "object", "required": ["id"], "properties": { "op": { "const": "delete" }, "id": { "type": "string" } } }
      ]
    },
    "setOperation": {
      "allOf": [
        { "$ref": "#/$defs/baseOperation" },
        { "type": "object", "required": ["id", "path", "value"], "properties": { "op": { "const": "set" }, "id": { "type": "string" }, "path": { "type": "string" }, "value": true } }
      ]
    },
    "animateOperation": {
      "allOf": [
        { "$ref": "#/$defs/baseOperation" },
        {
          "type": "object",
          "required": ["id", "path", "from", "to", "duration", "easing"],
          "properties": {
            "op": { "const": "animate" },
            "id": { "type": "string" },
            "path": { "type": "string" },
            "from": true,
            "to": true,
            "duration": { "type": "number", "minimum": 0 },
            "easing": { "enum": ["linear", "smooth", "easeInOut", "easeIn", "easeOut"] }
          }
        }
      ]
    },
    "effectOperation": {
      "allOf": [
        { "$ref": "#/$defs/baseOperation" },
        {
          "type": "object",
          "required": ["id", "effect", "duration", "easing"],
          "properties": {
            "op": { "const": "effect" },
            "id": { "type": "string" },
            "effect": { "enum": ["fadeIn", "fadeOut", "create", "write", "transform"] },
            "duration": { "type": "number", "minimum": 0 },
            "easing": { "enum": ["linear", "smooth", "easeInOut", "easeIn", "easeOut"] }
          }
        }
      ]
    }
  }
}
